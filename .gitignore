*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pytype/
.cache/

# -------------------------
# Virtual environments
# -------------------------
.venv/
venv/
env/
ENV/
.conda/
conda-env/

# -------------------------
# Jupyter / IPython
# -------------------------
.ipynb_checkpoints/
.ipython/

# -------------------------
# Streamlit
# -------------------------
.streamlit/secrets.toml
.streamlit/*.toml
!/.streamlit/config.toml

# Streamlit runtime files
.streamlit/cache/
*.streamlit

